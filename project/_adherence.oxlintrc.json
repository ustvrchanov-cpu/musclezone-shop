{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Button/**",
              "components/DataStrip/**",
              "components/Input/**",
              "components/ProductCard/**",
              "components/ShippingBar/**",
              "components/ZoneBadge/**",
              "tweaks-panel.jsx"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|type|onClick|ariaLabel|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, type, onClick, ariaLabel, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|icon)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'icon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<DataStrip> doesn't accept that prop. Declared props: items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|type|placeholder|hint|error|value|onChange|required|autoComplete|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: id, label, type, placeholder, hint, error, value, onChange, required, autoComplete."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|brand|price|unitPrice|data|badge|badgeTone|image|availability|onAdd|style|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, brand, price, unitPrice, data, badge, badgeTone, image, availability, onAdd, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='badgeTone'] > Literal[value!=/^(?:accent|ink|success)$/]",
        "message": "<ProductCard> badgeTone must be one of 'accent' | 'ink' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShippingBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|threshold|key|ref|className|style|children)$/]",
        "message": "<ShippingBar> doesn't accept that prop. Declared props: current, threshold."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZoneBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|rotate|key|ref|className|style|children)$/]",
        "message": "<ZoneBadge> doesn't accept that prop. Declared props: children, tone, solid, rotate."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZoneBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|ink|success)$/]",
        "message": "<ZoneBadge> tone must be one of 'accent' | 'ink' | 'success'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
      },
      "DataStrip": {
        "replaces": []
      },
      "Input": {
        "replaces": []
      },
      "ProductCard": {
        "replaces": []
      },
      "ShippingBar": {
        "replaces": []
      },
      "ZoneBadge": {
        "replaces": []
      }
    },
    "tokens": [
      "--accent",
      "--accent-strong",
      "--bg",
      "--border-w",
      "--container",
      "--danger",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--ink",
      "--ink-muted",
      "--line",
      "--on-accent",
      "--radius-lg",
      "--radius-md",
      "--radius-pill",
      "--radius-sm",
      "--space-1",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-5",
      "--space-6",
      "--space-7",
      "--space-8",
      "--success",
      "--surface",
      "--surface-2",
      "--tap-min",
      "--text-2xl",
      "--text-3xl",
      "--text-4xl",
      "--text-5xl",
      "--text-lg",
      "--text-md",
      "--text-sm",
      "--text-xl",
      "--text-xs"
    ],
    "tokenKinds": {
      "--bg": "color",
      "--surface": "color",
      "--surface-2": "color",
      "--ink": "color",
      "--ink-muted": "color",
      "--line": "color",
      "--accent": "color",
      "--accent-strong": "color",
      "--on-accent": "color",
      "--success": "color",
      "--danger": "color",
      "--font-display": "font",
      "--font-body": "font",
      "--font-mono": "font",
      "--text-xs": "font",
      "--text-sm": "font",
      "--text-md": "font",
      "--text-lg": "font",
      "--text-xl": "font",
      "--text-2xl": "font",
      "--text-3xl": "font",
      "--text-4xl": "font",
      "--text-5xl": "font",
      "--space-1": "spacing",
      "--space-2": "spacing",
      "--space-3": "spacing",
      "--space-4": "spacing",
      "--space-5": "spacing",
      "--space-6": "spacing",
      "--space-7": "spacing",
      "--space-8": "spacing",
      "--radius-sm": "radius",
      "--radius-md": "radius",
      "--radius-lg": "radius",
      "--radius-pill": "radius",
      "--border-w": "spacing",
      "--container": "spacing",
      "--tap-min": "spacing"
    },
    "fontFamilies": [
      "Archivo",
      "IBM Plex Mono"
    ]
  }
}